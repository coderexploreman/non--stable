PKG_NAME=wget
PKG_VERSION=
PKG_DEPENDS=
PKG_SOURCE_URL=#
PKG_BUILD_COMMANDS='
latest=$(wget -qO- https://ftp.gnu.org/gnu/wget/ | grep -o "wget-[0-9\.]*\.tar\.gz" | sort -V | tail -n1)
wget "https://ftp.gnu.org/gnu/wget/$latest" -O "$latest"
tar xf "$latest" --strip-components=1

./configure --prefix=/usr --with-ssl=openssl
make DESTDIR="$DESTDIR" install
'