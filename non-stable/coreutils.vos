PKG_NAME=coreutils
PKG_VERSION=
PKG_DEPENDS=
PKG_SOURCE_URL=#
PKG_BUILD_COMMANDS='
latest=$(wget -qO- https://ftp.gnu.org/gnu/coreutils/ | grep -o "coreutils-[0-9\.]*\.tar\.xz" | sort -V | tail -n1)
wget "https://ftp.gnu.org/gnu/coreutils/$latest" -O "$latest"
tar xf "$latest" --strip-components=1

./configure --prefix=/usr
make DESTDIR="$DESTDIR" install
'